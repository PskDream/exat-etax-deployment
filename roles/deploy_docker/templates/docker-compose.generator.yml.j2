services:
  {{ service_name }}:
    image: "{{ ecr_registry }}/{{ svc.repository }}:{{ image_tag }}"
    container_name: "{{ service_name }}"
    restart: always
    ports:
      - "{{ svc.app_port }}:{{ svc.container_port }}"
    env_file:
      - .env
    volumes:
{% for v in svc.volumes %}
        - "{{ v }}"
{% endfor %}
        - nfs-data:/data
    healthcheck:
      test: [ "CMD", "curl", "-f", "http://localhost:{{ svc.container_port }}{{ svc.health_path }}" ]
      interval: 10s
      timeout: 5s
      retries: 3
      start_period: 15s

volumes:
  nfs-data:
    driver: local
    driver_opts:
      type: nfs
      o: addr={{ svc.nfs_server_ip }},rw,sync,nfsvers=4
      device: ":{{ svc.nfs_device_path }}"
